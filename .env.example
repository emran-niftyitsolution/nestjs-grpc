# ===========================================================================
# .env.example  —  COMMITTED template. Contains NO real secrets.
#
# WHY this file exists: `.env` is gitignored, so a teammate cloning the repo
# has no idea which variables the project needs. This committed example is the
# documented contract. Onboarding step:
#
#     cp .env.example .env      # then edit the values
#
# Keep this file's KEY list identical to .env; only the secret VALUES differ.
# ===========================================================================

POSTGRES_USER=app
POSTGRES_PASSWORD=change_me      # placeholder — set a real value in .env
POSTGRES_DB=ecommerce
POSTGRES_PORT=5432

# Must mirror the POSTGRES_* values above (user:password@host:port/db).
DATABASE_URL=postgres://app:change_me@localhost:5432/ecommerce

GATEWAY_PORT=5001
AUTH_GRPC_PORT=50051       # auth-service gRPC port
PRODUCTS_GRPC_PORT=50052   # products-service gRPC port
ORDERS_GRPC_PORT=50053     # orders-service gRPC port

# JWT secret — used by auth-service to sign and verify tokens.
# Generate a strong value with: openssl rand -hex 32
JWT_SECRET=change_me

# --- gRPC URL overrides (Step 8 — Docker) ------------------------------------
# When running WITHOUT Docker, leave these UNSET. The apps fall back to
# localhost:PORT using the PORT vars above.
#
# When running IN Docker, docker-compose.yml sets these automatically to the
# Docker DNS names. You do NOT need to set them here for Docker.
#
# PRODUCTS_GRPC_URL=
# ORDERS_GRPC_URL=
# AUTH_GRPC_URL=

{
  // ----------------------------------------------------------------------
  // Per-LIBRARY tsconfig for libs/proto.
  //
  // KEY DIFFERENCE vs. the app configs: declaration = true. A library is
  // *consumed by other code*, so it must emit .d.ts type declarations; that
  // is what gives the gateway and products-service full type-safety and
  // autocomplete when they import from '@app/proto'.
  // ----------------------------------------------------------------------
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    // Emit .d.ts — consumers (the two apps) rely on these types.
    "declaration": true,
    "outDir": "../../dist/libs/proto"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
